{
  "version": "3.0",
  "description": "Extended feature configuration for S&P 500 prediction",

  "data_sources": {
    "price_data": "yfinance",
    "fundamental_data": "yfinance",
    "macro_data": "fredapi",
    "inequality_data": "worldbank"
  },

  "api_keys": {
    "fred_api_key": "YOUR_FRED_API_KEY",
    "alpha_vantage_key": "YOUR_ALPHA_VANTAGE_KEY"
  },

  "date_range": {
    "start_date": "2010-01-01",
    "end_date": "2025-12-31"
  },

  "feature_groups": {
    "technical": {
      "enabled": true,
      "features": [
        "returns", "ma_5", "ma_20", "ma_50", "volatility",
        "bollinger_upper", "bollinger_lower", "stochastic_k",
        "rsi", "macd", "macd_signal"
      ]
    },
    "direction": {
      "enabled": true,
      "windows": [5, 10, 20, 60],
      "features": ["avg_direction_5d", "avg_direction_10d", "avg_direction_20d", "avg_direction_60d"]
    },
    "ohlcv": {
      "enabled": true,
      "features": ["open", "high", "low", "close", "volume", "hl_spread", "oc_spread"]
    },
    "fundamental": {
      "enabled": true,
      "features": ["pe_ratio", "market_cap", "market_cap_log", "index_weight"]
    },
    "earnings": {
      "enabled": true,
      "features": ["quarterly_eps", "earnings_surprise", "earnings_growth_qoq"]
    },
    "macro": {
      "enabled": true,
      "features": ["cpi_yoy", "ppi_yoy", "inflation_expectation", "us_gdp_share", "fed_funds_rate"]
    },
    "inequality": {
      "enabled": true,
      "features": ["gini_index", "lorenz_area_ratio"]
    },
    "sector": {
      "enabled": true,
      "features": ["sector_lerner", "sector_hhi", "sector_avg_return", "sector_volatility"]
    }
  },

  "sectors": {
    "Technology": ["AAPL", "MSFT", "NVDA", "GOOGL", "META", "AVGO", "ORCL", "CRM", "AMD", "ADBE"],
    "Healthcare": ["UNH", "JNJ", "LLY", "PFE", "ABBV", "MRK", "TMO", "ABT", "DHR", "BMY"],
    "Financials": ["JPM", "BAC", "WFC", "GS", "MS", "BLK", "SCHW", "AXP", "C", "USB"],
    "Consumer_Discretionary": ["AMZN", "TSLA", "HD", "MCD", "NKE", "SBUX", "LOW", "TJX", "BKNG", "CMG"],
    "Communication_Services": ["GOOG", "META", "NFLX", "DIS", "CMCSA", "VZ", "T", "TMUS", "CHTR", "EA"],
    "Industrials": ["CAT", "UNP", "HON", "UPS", "BA", "RTX", "DE", "LMT", "GE", "MMM"],
    "Consumer_Staples": ["PG", "KO", "PEP", "COST", "WMT", "PM", "MO", "CL", "MDLZ", "EL"],
    "Energy": ["XOM", "CVX", "COP", "SLB", "EOG", "MPC", "PSX", "VLO", "OXY", "KMI"],
    "Utilities": ["NEE", "DUK", "SO", "D", "AEP", "SRE", "EXC", "XEL", "ED", "WEC"],
    "Real_Estate": ["PLD", "AMT", "EQIX", "CCI", "PSA", "O", "WELL", "DLR", "SPG", "AVB"],
    "Materials": ["LIN", "APD", "SHW", "ECL", "FCX", "NEM", "NUE", "DD", "DOW", "VMC"]
  },

  "fred_series": {
    "cpi": "CPIAUCSL",
    "ppi": "PPIACO",
    "breakeven_5y": "T5YIE",
    "fed_funds": "FEDFUNDS",
    "unemployment": "UNRATE",
    "gdp": "GDP",
    "m2": "M2SL"
  },

  "preprocessing": {
    "sequence_length": 60,
    "train_split": 0.7,
    "validation_split": 0.15,
    "test_split": 0.15,
    "scaling_method": "minmax",
    "handle_missing": "ffill_bfill"
  },

  "validation": {
    "compute_covariance": true,
    "redundancy_threshold": 0.95,
    "min_variance_threshold": 0.001
  }
}
